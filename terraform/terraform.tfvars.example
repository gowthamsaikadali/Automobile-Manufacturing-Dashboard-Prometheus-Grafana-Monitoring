aws_region   = "ap-south-1"
project_name = "automobile-project"
environment  = "dev"

# No db_password needed - it's auto-generated by Terraform (random_password)
# and stored in AWS Secrets Manager. Retrieve it later with:
#   aws secretsmanager get-secret-value --secret-id automobile-project-dev-db-credentials --query SecretString --output text
