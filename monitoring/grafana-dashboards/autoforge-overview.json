{
  "title": "AutoForge - App & Cluster Overview",
  "uid": "autoforge-overview",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Pod CPU Usage (autoforge namespace)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"autoforge\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pod Memory Usage (autoforge namespace)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"autoforge\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ready Pod Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"autoforge\", deployment=\"autoforge-app\"}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_duration_seconds_count[5m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 5,
      "title": "p95 Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 latency (s)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "100 * sum(rate(flask_http_request_duration_seconds_count{status=~\"5..\"}[5m])) / sum(rate(flask_http_request_duration_seconds_count[5m]))",
          "legendFormat": "error rate %"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pod Restarts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"autoforge\"}[10m])",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
