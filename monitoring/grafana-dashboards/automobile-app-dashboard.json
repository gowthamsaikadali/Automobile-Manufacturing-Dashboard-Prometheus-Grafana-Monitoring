{
  "title": "Automobile App - Health & Performance",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage per Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"automobile\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage per Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"automobile\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Available Pod Count",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_available{namespace=\"automobile\", deployment=\"automobile-app\"})"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(flask_http_request_total{namespace=\"automobile\"}[5m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 5,
      "title": "P95 Request Latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{namespace=\"automobile\"}[5m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 6,
      "title": "5xx Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "100 * sum(rate(flask_http_request_total{namespace=\"automobile\", status=~\"5..\"}[5m])) / sum(rate(flask_http_request_total{namespace=\"automobile\"}[5m]))",
          "legendFormat": "error rate %"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pod Restarts (15m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"automobile\"}[15m])",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
